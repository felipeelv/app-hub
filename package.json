{
  "name": "workspace",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "build": "pnpm run typecheck && pnpm -r --if-present run build",
    "build:api": "pnpm --filter @workspace/api-server run build",
    "build:admin": "pnpm --filter @workspace/admin-portal run build",
    "build:prestador": "pnpm --filter @workspace/prestador-portal run build",
    "build:cliente": "pnpm --filter @workspace/cliente-portal run build",
    "build:all": "pnpm run build",
    "typecheck:libs": "tsc --build",
    "typecheck": "pnpm run typecheck:libs && pnpm -r --if-present run typecheck",
    "dev:api": "pnpm --filter @workspace/api-server run dev",
    "dev:admin": "pnpm --filter @workspace/admin-portal run dev",
    "dev:prestador": "pnpm --filter @workspace/prestador-portal run dev",
    "dev:cliente": "pnpm --filter @workspace/cliente-portal run dev",
    "db:push": "pnpm --filter @workspace/db run push",
    "db:seed": "pnpm --filter @workspace/scripts run seed",
    "codegen": "pnpm --filter @workspace/api-spec run codegen"
  },
  "private": true,
  "devDependencies": {
    "typescript": "~5.9.2",
    "prettier": "^3.8.1"
  }
}
