modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
VITE_MAPBOX_TOKEN = "pk.eyJ1IjoiZmVsaXBlcm9zYWVsdiIsImEiOiJjbW1vMzJheTUwOTVmMm9wd2s3bzJ5cGJvIn0.4Yy2lvLSoqDBjoDvXgGkXg"

[nix]
channel = "stable-25_05"
